		<p class="kurzbeschreibung"><?= $artist->kurzbeschreibung ?></p>
		<br>
		
		<div class="data">
			Kulturform(en):<br>
			<span class="sparten"><?= trim(strtoupper(str_replace(',',' | ',$artist->sparten))) ?></span>
			<br><br>
			Zielgruppe(n):<br>
			<span class="zielgruppen"><?= trim(strtoupper(str_replace(',',' | ',$artist->zielgruppen))) ?></span>
			
		</div>
		
		<?php if(isset($kulturrouten[$artist->id])): ?>
			<br><br>
		Diese Veranstaltung liegt an der folgenden KulturRoute:
			<a href="https://se-kultur.de/kulturrouten.html#route<?= $kulturrouten[$artist->id] ?>" target="_blank"><span class="badge" style="background:orange"><i class="fa-solid fa-bicycle"></i> KulturRoute #<?= $kulturrouten[$artist->id] ?></span></a>
			<?php endif; ?>			
	</div>
	<div class="main col-9 col-md-8 col-sm-12">	
		<?php if(strlen($artist->zitat) > 0): ?>
		<h3>&bdquo;<?= $artist->zitat ?>&rdquo;</h3>
		<?php endif; ?>
		
		<div class="beschreibung mb-4"><?= $artist->beschreibung ?></div>
		
		<div class="termine mb-4">
			<h6><?= (count($dates) > 1) ? 'Termine' : 'Termin' ?></h6>
			<div class="table-responsive">
				<table>
					<thead>
						<tr>
							<th></th>
							<th>Beginn</th>
							<th>Ende</th>
							<th>Info</th>
						</tr>
					</thead>
					<tbody>
						<?php foreach($dates as $d): ?>
						<tr>
							<td style="width: 140px;"><?= $d['text'] ?></td>
							<td><?= $d['start'] ?> Uhr</td>
							<td><?= $d['end'] ?> Uhr</td>
							<td><?= $d['comment'] ?></td>
						</tr>
						<?php endforeach; ?>
					</tbody>
				</table>
			</div>
		</div>
		
		<?php if($artist->eintrittfrei !== '1'): ?>
		<div class="preise mb-4">
			<h6>Eintritt</h6>
			<div class="table-responsive">
				<table>
					<tbody>
						<?php foreach($prices as $d): ?>
						<tr>
							<td style="text-align: right; padding-right: 1em; width: 140px;"><?= str_replace('u20ac', '€', $d['price']) ?></td>

			<?php $linkedAvatar = \SeKultur\ContaoKulturnetzBundle\Helper\ImageHelper::resize(\SeKultur\ContaoKulturnetzBundle\Helper\ImageHelper::avatarPath($d->avatar_file), 120, 120, 'crop') ?: $noavatarSmall; ?>
			<a href="detailansicht-kuenstlerprofil/<?= $d->alias ?>.html" class="linked-profile"><img src="<?= $linkedAvatar ?>" alt=""> <?= $d->name ?></a>
			<?php endforeach; endif; ?>
			<?php if(strlen($artist->artists) > 0): echo '<strong>'.$artist->artists.'</strong>'; endif; ?>
		</div>
		
		<div class="hosts mb-4">
			<h6>Veranstalter*in(nen)</h6>
			<?php if(is_array($artist->linked_hosts_data)): foreach($artist->linked_hosts_data as $d): ?>
			<?php $linkedAvatar = \SeKultur\ContaoKulturnetzBundle\Helper\ImageHelper::resize(\SeKultur\ContaoKulturnetzBundle\Helper\ImageHelper::avatarPath($d->avatar_file), 120, 120, 'crop') ?: $noavatarSmall; ?>
			<a href="detailansicht-veranstalterprofil/<?= $d->alias ?>.html" class="linked-profile"><img src="<?= $linkedAvatar ?>" alt=""> <?= $d->name ?></a>

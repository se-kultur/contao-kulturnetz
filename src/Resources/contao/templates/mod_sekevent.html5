			<?php if(strlen($artist->host_telefon) > 0): ?><i class="fa-solid fa-phone-volume"></i> <a href="tel:<?= preg_replace('/[^0-9]+/', '', $artist->host_telefon) ?>" title="Telefonnummer anrufen"><?= $artist->host_telefon ?></a><br><?php endif; ?>
			<?php if(strlen($artist->host_email) > 0): ?><i class="fa-solid fa-at"></i> <a href="mailto:<?= $artist->host_email ?>" title="E-Mail schreiben"><?= $artist->host_email ?></a><br><?php endif; ?>
			<?php if(strlen($artist->host_website) > 0): ?><i class="fa-solid fa-globe"></i> <a href="https://<?= $artist->host_website ?>" title="Webseite öffnen" target="_blank"><?php $url = parse_url('https://'.$artist->host_website); echo $url['host'] ?></a><br><?php endif; ?>
		</div>
		
		<?php if(strlen($artist->kooperationspartner) > 0): ?>

			<?php if(strlen($artist->location_telefon) > 0): ?><i class="fa-solid fa-phone-volume"></i> <a href="tel:<?= preg_replace('/[^0-9]+/', '', $artist->location_telefon) ?>" title="Telefonnummer anrufen"><?= $artist->location_telefon ?></a><br><?php endif; ?>
			<?php if(strlen($artist->location_email) > 0): ?><i class="fa-solid fa-at"></i> <a href="mailto:<?= $artist->location_email ?>" title="E-Mail schreiben"><?= $artist->location_email ?></a><br><?php endif; ?>
			<?php if(strlen($artist->location_website) > 0): ?><i class="fa-solid fa-globe"></i> <a href="https://<?= $artist->location_website ?>" title="Webseite öffnen" target="_blank"><?php $url = parse_url('https://'.$artist->location_website); echo $url['host'] ?></a><br><?php endif; ?>
			<br>
			

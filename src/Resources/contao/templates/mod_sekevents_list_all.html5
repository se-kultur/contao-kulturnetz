<div id="sekevents_map"></div>
<script>
	<?php 
	foreach ($this->events as $kdate => $artist): 
		$mapData[$artist->id] = [
			'name' => $artist->name,
			'location' => $artist->location_adresse.', '.$artist->location_plz.' '.$artist->location_ort
		];
	endforeach; 
	echo 'const mapdata = '.json_encode(array_values($mapData)).';';
	?>

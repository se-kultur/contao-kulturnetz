<div class="artists-list">
	<?php
	$noavatarList = \SeKultur\ContaoKulturnetzBundle\Helper\ImageHelper::resize('files/se-kultur.de/img/noavatar.jpg', 272, 272, 'crop') ?: 'files/se-kultur.de/img/noavatar.jpg';
	$date = false;
	foreach ($this->events as $kdate => $artist):

	if($objFile = \Contao\FilesModel::findByUuid($artist->avatar)) {
		$imgPath = \SeKultur\ContaoKulturnetzBundle\Helper\ImageHelper::resize($objFile->path, 272, 272, 'crop') ?: $objFile->path;
		$imgMeta = ($objFile->meta != NULL) ? unserialize($objFile->meta)['de'] : false;
	} else {
		$imgPath = $noavatarList;
	}
	
	$kdate = explode('_', $kdate);
	$kdate = strtotime( date('Y-m-d', $kdate[0]));
	
	if($date == false || $date != date('d.m.Y', intval($kdate))):
	$date = date('d.m.Y', intval($kdate));
	?>
	<h4 class="mt-4<?php if($today > $kdate && !isset($_GET['datum'])) echo ' hidden'; ?>"><i class="fa-solid fa-calendar-days"></i> Events am <?= $date ?></h4>
	<?php endif; ?>
	
	<div class="artist<?php if($today > $kdate && !isset($_GET['datum'])) echo ' hidden'; ?>">
		<a href="detailansicht-sekultur-event/<?= $artist->alias ?>.html">
			<figure class="avatar">
				<img src="<?= $imgPath ?>" alt="<?= @$imgMeta['alt'] ?>" loading="lazy">
			</figure>
		</a>
		<div class="infos">
			<?php if($this->member_id == $artist->member_id): ?>
			<div class="badges">
				<?php if($artist->disable == '1'): ?>
				<span class="badge bg-error"><i class="fa-solid fa-eye-slash"></i><span class="hide-xs hide-sm hide-md"> Nicht öffentlich</span></span>
				<?php endif; ?>
				
				<!--<span class="badge bg-kulturnetz"><i class="fa-solid fa-circle-info"></i> Dein Profil</span>-->
				<?php if($artist->readonly !== '1'): ?>
				<a href="sekultur-event-bearbeiten/<?= $artist->alias ?>.html" class="btn btn-primary btn-sm">
					<i class="fa-solid fa-pen-to-square"></i><span class="hide-sm hide-xs hide-md"> Event bearbeiten</span>
				</a>
				<?php else: ?>
				<button onClick="return false;" class="btn btn-primary btn-sm" disabled aria-label="Bearbeitung durch Admins deaktiviert" role="tooltip">
					<i class="fa-solid fa-pen-to-square"></i><span class="hide-sm hide-xs hide-md"> Event bearbeiten</span>
				</button>
				<?php endif; ?>
				<a href="detailansicht-sekultur-event/<?= $artist->alias ?>.html#galerie" class="btn btn-outline btn-sm">
					<i class="fa-solid fa-images"></i><span class="hide-sm hide-xs hide-md"> Galerie</span>
				</a>
			</div>
			<?php endif; ?>
			
			<a href="detailansicht-sekultur-event/<?= $artist->alias ?>.html"><h6><?= $artist->name ?></h6></a>
			<p class="beschreibung">
				<span style="font-weight: bold;"><i class="fa-regular fa-clock"></i>
				<?php $f = 0; foreach($artist->dates_formatted as $tstamp => $df): $tstamp = explode('_', $tstamp)[0]; ?>
					<?php if($tstamp > $kdate && $tstamp < ($kdate+86400)): ?>
						<?php if($f == 0): ?>
						<?= $tage[date('l', $tstamp)].', '.date('d.m.Y - H:i', $tstamp) ?> Uhr
						<?php else: ?>
						<?= '+ '.date('H:i', $tstamp) ?> Uhr
						<?php endif; ?>
					<?php $f++; endif; ?>
				<?php endforeach; ?>
				</span><br><br>
				
				<?= $artist->kurzbeschreibung ?><br><br>
				
				<?php if($artist->eintrittfrei == '1'): ?>
				<span class="badge">Eintritt frei</span>
				<?php endif; ?>
				<?php if($artist->spenden == '1'): ?>
				<span class="badge">Spenden erbeten</span>
				<?php endif; ?>
				<?php if($artist->anmeldung == '1'): ?>
				<span class="badge">Anmeldung erforderlich</span>
				<?php endif; ?>
				<?php if(strlen($artist->zielgruppen) > 0): ?>
				<?php foreach(explode(',', $artist->zielgruppen) as $z): ?>
				<span class="badge bg-kulturtage"><?= $z ?></span>
				<?php endforeach; ?>
				<?php endif; ?>
				
				<span class="badge bg-<?= strtolower(substr($artist->kulturform,3)) ?>"><?= $artist->kulturform ?></span>
				
				
				<?php if(isset($kulturrouten[$artist->id])): ?>
				<a href="https://se-kultur.de/kulturrouten.html#route<?= $kulturrouten[$artist->id] ?>" target="_blank"><span class="badge" style="background:orange"><i class="fa-solid fa-bicycle"></i> KulturRoute #<?= $kulturrouten[$artist->id] ?></span></a>
				<?php endif; ?>
				
				<!--<strong>Nächster Termin:</strong> <?= date('d.m.y - H:i', $artist->nextdate) ?>-->
			</p>
			<div class="footer">
				<span class="sparten"><?= trim(strtoupper(str_replace(',',' | ',$artist->sparten))) ?></span>
				<span class="ort"><?= $artist->location_ort ?></span>
				<div>
					<a href="detailansicht-sekultur-event/<?= $artist->alias ?>.html"><i class="fa-solid fa-arrow-right-long"></i></a>
				</div>
			</div>
		</div>
	</div>
	<?php endforeach; ?>
</div>